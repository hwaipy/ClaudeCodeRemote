# ClaudeCodeRemote Hub 环境变量. 复制到 ~/.config/ccr-hub/env.
CCR_HUB_DB=/home/youruser/.local/share/ccr-hub/hub.db
CCR_HUB_ADMIN_EMAIL=you@example.com
# 第一次启动时, hub 会用这个密码 ensure_admin (sha256 落库).
# 修改后请配合 db 里的 password_hash 一起改 (v0 不带 change-password endpoint).
CCR_HUB_ADMIN_PW=__set-a-strong-password__

# 可选: hub 监听地址 (默认 127.0.0.1:1885, 经 nginx TLS 暴露).
# CCR_HUB_HOST=127.0.0.1
# CCR_HUB_PORT=1885
