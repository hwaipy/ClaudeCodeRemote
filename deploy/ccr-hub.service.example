[Unit]
Description=ClaudeCodeRemote Hub (central server for multi-app fan-in)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/codes/ClaudeCodeRemote
EnvironmentFile=%h/.config/ccr-hub/env
ExecStart=/usr/bin/python3 -u -m uvicorn claude_code_remote.hub.main:app \
    --host 127.0.0.1 --port 1885 --log-level info
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ccr-hub

[Install]
WantedBy=default.target
