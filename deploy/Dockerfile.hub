FROM python:3.12-slim

WORKDIR /app

# Hub 依赖 (跟 app 共享一份 requirements). 国内构建环境用 tuna mirror, 否则
# files.pythonhosted.org 经常 timeout. ARG 让上层 build 时可覆盖.
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --timeout 120 --retries 5 \
        -i ${PIP_INDEX} -r /app/requirements.txt

# 项目代码 (hub 需要 server/static/, server/__init__.py 用作 STATIC_DIR 锚)
COPY claude_code_remote /app/claude_code_remote

ENV PYTHONUNBUFFERED=1 \
    CCR_HUB_DB=/data/hub.db

EXPOSE 1885

CMD ["python3", "-m", "uvicorn", \
     "claude_code_remote.hub.main:app", \
     "--host", "0.0.0.0", "--port", "1885", \
     "--log-level", "info"]
