# ClaudeCodeRemote 环境变量示例。复制到 ~/.config/ccr/env 并填入真值。
# 至少必须设 CCR_TOKEN。
CCR_TOKEN=__请用 `openssl rand -hex 24` 生成替换__

# 可选：覆盖默认值
# CCR_HOST=0.0.0.0
# CCR_PORT=1881
# CCR_DEFAULT_CWD=/home/youruser/codes
# CCR_DB_PATH=/home/youruser/.local/share/ccr/ccr.sqlite
# CCR_HIBERNATE_IDLE_S=1800
# CCR_CLAUDE_BIN=/path/to/claude
